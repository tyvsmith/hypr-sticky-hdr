#!/usr/bin/env bash
set -uo pipefail

# =============================================================================
# hypr-sticky-hdr — Sticky HDR for Hyprland
#
# Daemon that auto-detects HDR windows by scanning process env vars and keeps
# the monitor in HDR mode for the process's entire lifetime — no flickering
# on alt-tab. Detects any window whose process has PROTON_ENABLE_HDR=1 or
# HYPR_STICKY_HDR=1 set.
#
# Usage:
#   hypr-sticky-hdr daemon    Start the daemon (use in autostart.conf)
#   hypr-sticky-hdr on        Manual HDR on
#   hypr-sticky-hdr off       Manual HDR off
#   hypr-sticky-hdr status    Print current state
# =============================================================================

# --- Configuration -----------------------------------------------------------

MONITOR_NAME=""

HDR_CM="hdr"
HDR_SDR_BRIGHTNESS=1.35

SDR_CM="auto"
SDR_SDR_BRIGHTNESS=1.0

# Env vars that trigger HDR when found in a window's process
HDR_ENV_VARS=("PROTON_ENABLE_HDR=1" "HYPR_STICKY_HDR=1")

COOLDOWN=2
DEBOUNCE=0.2

CMD_FIFO="/tmp/hypr-sticky-hdr-${UID}.fifo"
REPLY_DIR="/tmp/hypr-sticky-hdr-${UID}-replies"
HYPR_SOCKET="/run/user/${UID}/hypr/${HYPRLAND_INSTANCE_SIGNATURE}/.socket2.sock"

MONITOR_BASE=""

# --- State -------------------------------------------------------------------

GAME_COUNT=0
MANUAL_ON=0
CURRENT_MODE="sdr"
COOLDOWN_PID=""
DEBOUNCE_PID=""
LAST_GAME_LIST=""
declare -A PID_CACHE=()

# --- Helpers -----------------------------------------------------------------

log() {
    echo "[hypr-sticky-hdr] $(date '+%H:%M:%S') $*" >&2
}

is_hdr_pid() {
    local pid="$1"
    [[ -n "$pid" && "$pid" != "null" ]] || return 1
    if [[ -n "${PID_CACHE[$pid]+x}" ]]; then
        [[ "${PID_CACHE[$pid]}" == "hdr" ]]; return
    fi
    if [[ -r "/proc/$pid/environ" ]]; then
        local env
        env=$(tr '\0' '\n' < "/proc/$pid/environ" 2>/dev/null) || { PID_CACHE[$pid]="no"; return 1; }
        for var in "${HDR_ENV_VARS[@]}"; do
            if echo "$env" | grep -qx "$var"; then
                PID_CACHE[$pid]="hdr"
                return 0
            fi
        done
    fi
    PID_CACHE[$pid]="no"
    return 1
}

prune_pid_cache() {
    for pid in "${!PID_CACHE[@]}"; do
        [[ -d "/proc/$pid" ]] || unset 'PID_CACHE[$pid]'
    done
}

hdr_demand() {
    echo $((GAME_COUNT + MANUAL_ON))
}

scan_windows() {
    local clients
    clients=$(hyprctl clients -j 2>/dev/null) || return

    local count=0 game_names=""
    while IFS=$'\t' read -r addr class pid; do
        if is_hdr_pid "$pid"; then
            count=$((count + 1))
            game_names+="  ${class} (${addr})"$'\n'
        fi
    done < <(echo "$clients" | jq -r '.[] | "\(.address)\t\(.class)\t\(.pid)"')

    local prev_demand
    prev_demand=$(hdr_demand)
    GAME_COUNT=$count
    LAST_GAME_LIST="$game_names"
    local new_demand
    new_demand=$(hdr_demand)

    if [[ "$new_demand" -gt 0 && "$prev_demand" -eq 0 ]]; then
        log "HDR demand started (detected=$count)"
        cancel_cooldown
        switch_hdr
    elif [[ "$new_demand" -eq 0 && "$prev_demand" -gt 0 ]]; then
        log "HDR demand ended"
        prune_pid_cache
        start_cooldown
    elif [[ "$new_demand" -gt 0 ]]; then
        cancel_cooldown
    fi
}

read_monitor() {
    local json
    json=$(hyprctl monitors -j 2>/dev/null) || { log "Failed to read monitors"; return 1; }
    if [[ -z "$MONITOR_NAME" ]]; then
        MONITOR_NAME=$(echo "$json" | jq -r '.[0].name')
    fi
    local fields
    fields=$(echo "$json" | jq -r --arg name "$MONITOR_NAME" '
        .[] | select(.name == $name) |
        "\(.name)\t\(.width)\t\(.height)\t\(.refreshRate)\t\(.scale)\t\(.transform)\t\(if .vrr then "1" else "0" end)\t\(.colorManagementPreset)\t\(.sdrBrightness)\t\(.sdrSaturation)\t\(.currentFormat)"
    ') || return 1
    local name width height rate scale transform vrr cm sdrb sdrs fmt
    IFS=$'\t' read -r name width height rate scale transform vrr cm sdrb sdrs fmt <<< "$fields"
    local bitdepth=8
    if [[ "$fmt" == *"2101010"* || "$fmt" == *"1010102"* ]]; then bitdepth=10; fi
    MONITOR_BASE="${name},${width}x${height}@${rate},auto,${scale}"
    MONITOR_BASE+=",bitdepth,${bitdepth},vrr,${vrr}"
    if [[ "$transform" != "0" ]]; then MONITOR_BASE+=",transform,${transform}"; fi
    MONITOR_BASE+=",sdrsaturation,${sdrs}"
    if [[ "$cm" == "hdr" ]]; then CURRENT_MODE="hdr"; else CURRENT_MODE="sdr"; fi
    log "Monitor: $name ${width}x${height}@${rate} bitdepth=${bitdepth} cm=${cm} sdrB=${sdrb} (mode=${CURRENT_MODE})"
}

build_monitor_string() {
    if [[ "$1" == "hdr" ]]; then
        echo "${MONITOR_BASE},cm,${HDR_CM},sdrbrightness,${HDR_SDR_BRIGHTNESS}"
    else
        echo "${MONITOR_BASE},cm,${SDR_CM},sdrbrightness,${SDR_SDR_BRIGHTNESS}"
    fi
}

switch_hdr() {
    [[ "$CURRENT_MODE" == "hdr" ]] && return
    local mon_str
    mon_str=$(build_monitor_string "hdr")
    log "Switching to HDR"
    hyprctl keyword render:cm_auto_hdr 0 >/dev/null
    hyprctl keyword monitor "$mon_str" >/dev/null
    notify-send -t 3000 "Sticky HDR" "HDR enabled" 2>/dev/null || true
    CURRENT_MODE="hdr"
}

switch_sdr() {
    [[ "$CURRENT_MODE" == "sdr" ]] && return
    local mon_str
    mon_str=$(build_monitor_string "sdr")
    log "Switching to SDR"
    hyprctl keyword monitor "$mon_str" >/dev/null
    hyprctl keyword render:cm_auto_hdr 2 >/dev/null
    notify-send -t 3000 "Sticky HDR" "HDR disabled" 2>/dev/null || true
    CURRENT_MODE="sdr"
}

cancel_cooldown() {
    if [[ -n "$COOLDOWN_PID" ]] && kill -0 "$COOLDOWN_PID" 2>/dev/null; then
        kill "$COOLDOWN_PID" 2>/dev/null || true
        wait "$COOLDOWN_PID" 2>/dev/null || true
        COOLDOWN_PID=""
    fi
}

start_cooldown() {
    cancel_cooldown
    ( sleep "$COOLDOWN"; echo "CMD:__cooldown__:" > "$CMD_FIFO" 2>/dev/null || true ) &
    COOLDOWN_PID=$!
    log "Cooldown started (${COOLDOWN}s)"
}

cancel_debounce() {
    if [[ -n "$DEBOUNCE_PID" ]] && kill -0 "$DEBOUNCE_PID" 2>/dev/null; then
        kill "$DEBOUNCE_PID" 2>/dev/null || true
        wait "$DEBOUNCE_PID" 2>/dev/null || true
        DEBOUNCE_PID=""
    fi
}

schedule_scan() {
    cancel_debounce
    ( sleep "$DEBOUNCE"; echo "CMD:__scan__:" > "$CMD_FIFO" 2>/dev/null || true ) &
    DEBOUNCE_PID=$!
}

# --- Command handling --------------------------------------------------------

handle_command() {
    local cmd="$1"
    local extra="${2:-}"
    local output=""
    local reply_file=""
    if [[ -n "$extra" && -p "$REPLY_DIR/$extra" ]]; then
        reply_file="$REPLY_DIR/$extra"
    fi

    case "$cmd" in
        status)
            output="display=$CURRENT_MODE detected=$GAME_COUNT manual=$MANUAL_ON"
            if [[ -n "$LAST_GAME_LIST" ]]; then
                output+=$'\n'"$LAST_GAME_LIST"
            fi
            ;;
        on)
            MANUAL_ON=1
            cancel_cooldown
            switch_hdr
            output="HDR on"
            ;;
        off)
            MANUAL_ON=0
            if [[ "$(hdr_demand)" -eq 0 ]]; then
                start_cooldown
            fi
            output="HDR manual off"
            ;;
        __window__)
            if [[ "$(hdr_demand)" -eq 0 && "$extra" == "close" ]]; then
                return
            fi
            schedule_scan
            return
            ;;
        __scan__)
            DEBOUNCE_PID=""
            scan_windows
            return
            ;;
        __cooldown__)
            COOLDOWN_PID=""
            if [[ "$(hdr_demand)" -eq 0 ]]; then
                log "Cooldown expired, switching to SDR"
                switch_sdr
            fi
            return
            ;;
        *)
            output="Unknown command: $cmd"
            ;;
    esac

    log "$output"
    if [[ -n "$reply_file" ]]; then
        echo "$output" > "$reply_file"
    fi
}

# --- Daemon ------------------------------------------------------------------

run_daemon() {
    if [[ -p "$CMD_FIFO" ]]; then
        if echo "CMD:status:" > "$CMD_FIFO" 2>/dev/null; then
            log "Daemon already running. Remove $CMD_FIFO to force."
            exit 1
        fi
    fi

    rm -f "$CMD_FIFO"
    mkfifo "$CMD_FIFO"
    mkdir -p "$REPLY_DIR"

    cleanup() {
        log "Shutting down"
        rm -f "$CMD_FIFO"
        rm -rf "$REPLY_DIR"
        cancel_cooldown
        cancel_debounce
        jobs -p | xargs -r kill 2>/dev/null || true
        wait 2>/dev/null || true
    }
    trap cleanup EXIT INT TERM

    read_monitor || { log "Failed to read monitor config"; exit 1; }
    log "Daemon starting (display=$CURRENT_MODE)"

    (
        socat -u UNIX-CONNECT:"$HYPR_SOCKET" - 2>/dev/null | while IFS= read -r line; do
            case "$line" in
                openwindow\>\>*)  echo "CMD:__window__:open" > "$CMD_FIFO" 2>/dev/null || break ;;
                closewindow\>\>*) echo "CMD:__window__:close" > "$CMD_FIFO" 2>/dev/null || break ;;
            esac
        done
        log "Event listener disconnected"
        echo "CMD:__shutdown__:" > "$CMD_FIFO" 2>/dev/null || true
    ) &

    ( while true; do sleep 30; echo "CMD:__scan__:" > "$CMD_FIFO" 2>/dev/null || break; done ) &

    exec 3<>"$CMD_FIFO"

    while IFS= read -r line <&3; do
        case "$line" in
            CMD:*:*)
                local payload="${line#CMD:}"
                local cmd="${payload%%:*}"
                local extra="${payload#*:}"
                if [[ "$cmd" == "__shutdown__" ]]; then
                    log "Event listener lost, exiting"
                    break
                fi
                handle_command "$cmd" "$extra"
                ;;
        esac
    done
}

# --- Client ------------------------------------------------------------------

send_command() {
    local cmd="$1"
    if [[ ! -p "$CMD_FIFO" ]]; then
        echo "Daemon not running" >&2
        exit 1
    fi
    local reply_id="$$"
    local reply_fifo="$REPLY_DIR/$reply_id"
    mkdir -p "$REPLY_DIR"
    rm -f "$reply_fifo"
    mkfifo "$reply_fifo"
    echo "CMD:${cmd}:${reply_id}" > "$CMD_FIFO" 2>/dev/null || {
        echo "Failed to send command" >&2
        rm -f "$reply_fifo"
        exit 1
    }
    local reply
    if reply=$(timeout 3 cat "$reply_fifo" 2>/dev/null); then
        echo "$reply"
    else
        echo "Timeout waiting for reply" >&2
    fi
    rm -f "$reply_fifo"
}

# --- Main --------------------------------------------------------------------

case "${1:-}" in
    daemon) run_daemon ;;
    on)     send_command "on" ;;
    off)    send_command "off" ;;
    status) send_command "status" ;;
    *)
        echo "Usage: hypr-sticky-hdr {daemon|on|off|status}"
        exit 1
        ;;
esac
